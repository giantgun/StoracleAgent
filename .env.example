# Server Environment Variables
# Copy this file to .env and fill in the values

# Required - Supabase
SUPABASE_URL=your_supabase_project_url
SUPABASE_SECRET_KEY=your_supabase_service_role_key

# Required - AI Services
GOOGLE_API_KEY=your_gemini_api_key
AGENT_MAIL_API_KEY=your_AGENT_MAIL_API_KEY

# Required - Session Key Security
MASTER_SESSION_PRIVATE_KEY=0xyour_hex_private_key_here

# Required - Blockchain
CHAIN_RPC_URL=https://testnet.hsk.xyz
USDT_TOKEN_ADDRESS=0xyour_usdt_contract_address_on_hashkey_testnet
BUNDLER_URL=http://localhost:4337

# Required - Server
SERVER_PORT=3000

# Required for email webhook - Ngrok tunnel so AgentMail can reach the server
NGROK_AUTHTOKEN=your_ngrok_authtoken_for_public_webhook
NODE_ENV=development
